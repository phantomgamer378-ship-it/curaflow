# === PostgreSQL / Prisma ===
DATABASE_URL=postgresql://user:password@localhost:5432/clinic_db

# === Express API Server ===
PORT=4000
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
ALLOWED_ORIGINS=http://localhost:3000

# === Redis (BullMQ + Socket.IO adapter) ===
UPSTASH_REDIS_URL=redis://localhost:6379

# === Notifications ===
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# === Google OAuth (Express backend) ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# === AI ===
# The current model registry uses Groq's OpenAI-compatible API.
GROQ_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# === Observability ===
SENTRY_DSN=

# === Deployment ===
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# === Legacy Supabase (keep during migration, remove after cutover) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
